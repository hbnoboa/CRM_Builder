{
  "subEntities": [
    {
      "name": "Item da Carga",
      "slug": "item-carga",
      "description": "Itens individuais da carga transportada",
      "parentEntity": "sinistro-transporte",
      "fields": [
        {
          "slug": "descricao",
          "name": "Descrição do Item",
          "type": "text",
          "required": true
        },
        {
          "slug": "codigoNCM",
          "name": "Código NCM",
          "type": "text",
          "settings": {
            "maxLength": 8
          },
          "helpText": "Nomenclatura Comum do Mercosul"
        },
        {
          "slug": "quantidade",
          "name": "Quantidade",
          "type": "number",
          "required": true,
          "settings": {
            "min": 0,
            "step": 1
          }
        },
        {
          "slug": "unidadeMedida",
          "name": "Unidade de Medida",
          "type": "select",
          "settings": {
            "options": [
              { "value": "un", "label": "Unidade" },
              { "value": "cx", "label": "Caixa" },
              { "value": "kg", "label": "Quilograma" },
              { "value": "ton", "label": "Tonelada" },
              { "value": "m", "label": "Metro" },
              { "value": "m2", "label": "Metro Quadrado" },
              { "value": "m3", "label": "Metro Cúbico" },
              { "value": "lt", "label": "Litro" }
            ]
          }
        },
        {
          "slug": "valorUnitario",
          "name": "Valor Unitário",
          "type": "currency",
          "required": true,
          "settings": {
            "prefix": "R$",
            "decimalPlaces": 2
          }
        },
        {
          "slug": "valorTotal",
          "name": "Valor Total",
          "type": "formula",
          "readonly": true,
          "settings": {
            "formula": "quantidade * valorUnitario"
          }
        },
        {
          "slug": "avariado",
          "name": "Item Avariado?",
          "type": "boolean",
          "settings": {
            "defaultValue": false
          }
        },
        {
          "slug": "percentualAvaria",
          "name": "Percentual de Avaria",
          "type": "percentage",
          "conditionalDisplay": {
            "field": "avariado",
            "operator": "equals",
            "value": true
          },
          "settings": {
            "min": 0,
            "max": 100,
            "decimalPlaces": 2
          }
        },
        {
          "slug": "valorPrejuizo",
          "name": "Valor do Prejuízo",
          "type": "formula",
          "readonly": true,
          "conditionalDisplay": {
            "field": "avariado",
            "operator": "equals",
            "value": true
          },
          "settings": {
            "formula": "valorTotal * (percentualAvaria / 100)"
          }
        },
        {
          "slug": "fotosItem",
          "name": "Fotos do Item",
          "type": "image",
          "settings": {
            "multiple": true,
            "maxFiles": 10,
            "imageSource": "both"
          }
        },
        {
          "slug": "observacoes",
          "name": "Observações",
          "type": "textarea"
        }
      ]
    },
    {
