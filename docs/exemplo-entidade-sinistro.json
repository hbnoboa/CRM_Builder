          }
        },
        {
          "slug": "causaSinistro",
          "name": "Causas do Sinistro",
          "type": "multiselect",
          "settings": {
            "options": [
              { "value": "condicao_estrada", "label": "Condição da estrada" },
              { "value": "clima", "label": "Condições climáticas" },
              { "value": "falha_mecanica", "label": "Falha mecânica" },
              { "value": "erro_motorista", "label": "Erro do motorista" },
              { "value": "terceiros", "label": "Ação de terceiros" },
              { "value": "ma_amarracao", "label": "Má amarração da carga" },
              { "value": "sobrecarga", "label": "Sobrecarga" },
              { "value": "fadiga", "label": "Fadiga do motorista" }
            ]
          }
        },
        {
          "slug": "descricaoDetalhada",
          "name": "Descrição Detalhada",
          "type": "richtext",
          "required": true,
          "helpText": "Relato completo de como o sinistro ocorreu"
        },
        {
          "slug": "houveFeridos",
          "name": "Houve Feridos?",
          "type": "boolean"
        },
        {
          "slug": "houveVitimas",
          "name": "Houve Vítimas Fatais?",
          "type": "boolean"
        },
        {
          "slug": "houveBoletimOcorrencia",
          "name": "Foi Registrado Boletim de Ocorrência?",
          "type": "boolean"
        },
        {
          "slug": "numeroBO",
          "name": "Número do Boletim de Ocorrência",
          "type": "text",
          "conditionalDisplay": {
            "field": "houveBoletimOcorrencia",
            "operator": "equals",
            "value": true
          }
        },
        {
          "slug": "arquivoBO",
          "name": "Arquivo do Boletim de Ocorrência",
          "type": "file",
          "conditionalDisplay": {
            "field": "houveBoletimOcorrencia",
            "operator": "equals",
            "value": true
          }
        },
        {
          "slug": "testemunhas",
          "name": "Testemunhas",
          "type": "array",
          "helpText": "Nome e contato das testemunhas"
        },
        {
          "slug": "fotosLocal",
          "name": "Fotos do Local",
          "type": "image",
          "settings": {
            "multiple": true,
            "maxFiles": 20,
            "imageSource": "both",
            "imageDisplaySize": 150
          }
        },
        {
          "slug": "fotosCarga",
          "name": "Fotos da Carga",
          "type": "image",
          "settings": {
            "multiple": true,
            "maxFiles": 30,
            "imageSource": "both"
          }
        },
        {
          "slug": "fotosVeiculo",
          "name": "Fotos do Veículo",
          "type": "image",
          "settings": {
            "multiple": true,
            "maxFiles": 20,
            "imageSource": "both"
          }
        },
        {
          "slug": "diagramaAvarias",
          "name": "Diagrama de Avarias",
          "type": "zone-diagram",
          "helpText": "Marque as áreas danificadas no diagrama"
        }
      ]
    },
    {
      "section": "avaliacao",
