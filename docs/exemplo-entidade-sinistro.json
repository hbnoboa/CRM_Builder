        },
        {
          "slug": "destino",
          "name": "Destino (Cidade/Estado)",
          "type": "text",
          "required": true
        },
        {
          "slug": "destinoCEP",
          "name": "CEP de Destino",
          "type": "cep"
        },
        {
          "slug": "localSinistro",
          "name": "Local Exato do Sinistro",
          "type": "text",
          "required": true,
          "helpText": "Endereço ou referência exata onde ocorreu o sinistro"
        },
        {
          "slug": "localSinistroCEP",
          "name": "CEP do Local do Sinistro",
          "type": "cep"
        },
        {
          "slug": "localSinistroMapa",
          "name": "Mapa do Local",
          "type": "map",
          "settings": {
            "mapMode": "both",
            "mapHeight": 400,
            "defaultZoom": 15
          }
        },
        {
          "slug": "numeroCTe",
          "name": "Número do CT-e",
          "type": "text"
        },
        {
          "slug": "arquivoCTe",
          "name": "Arquivo do CT-e",
          "type": "file",
          "settings": {
            "multiple": false,
            "acceptedTypes": ["application/pdf", "application/xml"]
          }
        }
      ]
    },
    {
      "section": "ocorrencia",
