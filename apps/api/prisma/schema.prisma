// CRM BUILDER - Database Schema
// PostgreSQL 16 + Prisma 5.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// UserRole enum REMOVIDO - agora usamos CustomRole.roleType
// Tipos validos: PLATFORM_ADMIN, ADMIN, MANAGER, USER, VIEWER, CUSTOM

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

// ═══════════════════════════════════════════════════════════════════════════
// PDF TEMPLATES - Enums
// ═══════════════════════════════════════════════════════════════════════════

enum PdfPageSize {
  A4
  LETTER
  LEGAL
}

enum PdfOrientation {
  PORTRAIT
  LANDSCAPE
}

enum PdfGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ═══════════════════════════════════════════════════════════════════════════
// TENANT (Empresa)
// ═══════════════════════════════════════════════════════════════════════════

model Tenant {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  domain   String? @unique
  logo     String?
  settings Json    @default("{}")

  status Status @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  users            User[]
  entities         Entity[]
  entityData       EntityData[]
  archivedData     ArchivedEntityData[]
  customRoles      CustomRole[]
  notifications    Notification[]
  pdfTemplates     PdfTemplate[]
  pdfGenerations   PdfGeneration[]
  userTenantAccess UserTenantAccess[]

  // Automacoes
  webhooks       Webhook[]
  emailTemplates EmailTemplate[]
  actionChains   ActionChain[]
  scheduledTasks ScheduledTask[]

  // Automacoes Unificadas
  entityAutomations    EntityAutomation[]
  automationExecutions AutomationExecution[]
  entityFieldRules     EntityFieldRule[]
  dashboardTemplates   DashboardTemplate[]
  publicLinks          PublicLink[]

  @@index([slug])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id       String @id @default(cuid())
  tenantId String

  email    String
  password String
  name     String
  avatar   String?

  // Identificacao adicional (para usuarios publicos via weblinks)
  cpf   String? // Digitos: 00000000000
  cnpj  String? // Digitos: 00000000000000
  phone String? // Digitos: 00000000000

  // role REMOVIDO - agora usamos apenas customRole.roleType
  customRoleId String
  status       Status @default(ACTIVE)

  lastLoginAt       DateTime?
  resetToken        String?
  resetTokenExpires DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relacionamentos
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole    CustomRole     @relation(fields: [customRoleId], references: [id])
  refreshTokens RefreshToken[]
  notifications Notification[]
  deviceTokens  DeviceToken[]

  // Dados criados por este usuario
  createdData EntityData[] @relation("CreatedBy")
  updatedData EntityData[] @relation("UpdatedBy")

  // PDFs solicitados por este usuario
  pdfGenerations PdfGeneration[]

  // Acessos a outros tenants (multi-tenant por usuario)
  tenantAccess UserTenantAccess[]

  @@unique([tenantId, email])
  @@unique([tenantId, cpf])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([cpf])
  @@index([phone])
  @@index([status])
  @@index([tenantId, status])
  @@index([customRoleId])
  @@index([tenantId, createdAt(sort: Desc)])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "android" | "ios" | "web"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTITY BUILDER (Entidades Dinamicas)
// ═══════════════════════════════════════════════════════════════════════════

model Entity {
  id       String @id @default(cuid())
  tenantId String

  name        String
  namePlural  String
  slug        String
  description String?
  icon        String?
  color       String?

  fields   Json // [{ slug, name, type, required, options, ... }]
  settings Json    @default("{}")
  category String?
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  data         EntityData[]
  archivedData ArchivedEntityData[]
  pdfTemplates PdfTemplate[]
  automations  EntityAutomation[]
  fieldRules   EntityFieldRule[]
  publicLinks  PublicLink[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, category])
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTITY DATA (Dados das Entidades)
// ═══════════════════════════════════════════════════════════════════════════

model EntityData {
  id       String @id @default(cuid())
  tenantId String
  entityId String

  data Json

  // Materialized computed field values (formulas, rollups, timers, sla-status)
  // Invalidated and recomputed when dependencies change
  computedValues Json @default("{}")

  // Sub-entity support: links child records to a parent record
  parentRecordId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  // Soft delete for PowerSync sync (tracks deletions for mobile)
  deletedAt DateTime?

  // Trigger-maintained: true if record passes entity's globalFilters
  // Used by PowerSync sync rules to filter at sync time
  matchesGlobalFilter Boolean @default(true) @map("_matchesGlobalFilter")

  // Trigger-maintained: true if parent record passes filters (for sub-entities)
  // Sub-entities only sync if parent also passes
  parentMatchesFilter Boolean @default(true) @map("_parentMatchesFilter")

  // Trigger-maintained: array of CustomRole IDs that can see this record
  // NULL = all roles can see (no role filters configured for this entity)
  // Empty array = no roles can see
  // Array with IDs = only those roles can see
  // PLATFORM_ADMIN and ADMIN always see everything (handled in sync rules)
  visibleToRoles String[] @map("_visibleToRoles")

  // Trigger-maintained: PowerSync-compatible columns derived from _visibleToRoles
  // _hasRoleFilter: true if any role has data filters for this entity
  // _visibleToRolesJson: JSONB array of role IDs (PowerSync IN operator needs JSONB, not TEXT[])
  hasRoleFilter      Boolean @default(false) @map("_hasRoleFilter")
  visibleToRolesJson Json    @default("[]") @map("_visibleToRolesJson")

  entity       Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("UpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  parentRecord EntityData?  @relation("SubRecords", fields: [parentRecordId], references: [id], onDelete: Cascade)
  childRecords EntityData[] @relation("SubRecords")

  @@index([tenantId])
  @@index([entityId])
  @@index([createdAt])
  @@index([createdById])
  @@index([tenantId, entityId])
  @@index([tenantId, entityId, createdAt(sort: Desc)])
  @@index([entityId, createdAt(sort: Desc)])
  @@index([entityId, createdById])
  @@index([parentRecordId])
  @@index([entityId, parentRecordId])
  @@index([updatedById])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([computedValues], type: Gin)
}

// ═══════════════════════════════════════════════════════════════════════════
// ARCHIVED ENTITY DATA (Dados Arquivados — sem colunas PowerSync)
// ═══════════════════════════════════════════════════════════════════════════

model ArchivedEntityData {
  id             String   @id
  tenantId       String
  entityId       String
  data           Json
  computedValues Json     @default("{}")
  parentRecordId String?
  createdAt      DateTime
  updatedAt      DateTime
  createdById    String?
  updatedById    String?
  archivedAt     DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entityId])
  @@index([tenantId, entityId])
  @@index([tenantId, entityId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([archivedAt])
  @@index([computedValues], type: Gin)
}

// ═══════════════════════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, action])
  @@index([tenantId, resource])
  @@index([tenantId, userId])
  @@index([resource, resourceId])
  @@index([tenantId, action, resource])
}

model ArchivedAuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  metadata   Json?
  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([archivedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════════════

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id         String           @id @default(cuid())
  tenantId   String
  userId     String
  type       NotificationType @default(INFO)
  title      String
  message    String
  data       Json?
  entitySlug String?
  read       Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@index([tenantId, userId])
  @@index([entitySlug])
}

// ═══════════════════════════════════════════════════════════════════════════
// CUSTOM ROLES (Papeis customizaveis por tenant)
// ═══════════════════════════════════════════════════════════════════════════

model CustomRole {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  color       String? @default("#6366f1")

  // Tipo da role: PLATFORM_ADMIN, ADMIN, MANAGER, USER, VIEWER, CUSTOM
  roleType String @default("CUSTOM")

  // Marca roles pre-configuradas do sistema (nome e roleType protegidos)
  isSystem Boolean @default(false)

  // JSON array de permissoes por entidade
  // Formato: [{ "entitySlug": "clientes", "canCreate": true, "canRead": true, "canUpdate": true, "canDelete": false, "scope": "all"|"own" }]
  permissions Json @default("[]")

  // Permissoes globais (modulos do sistema)
  // Formato: { "dashboard": true, "users": false, "settings": false, "apis": false, "pages": false, "entities": false }
  modulePermissions Json @default("{}")

  // Permissoes de tenant (apenas para PLATFORM_ADMIN)
  // Formato: { "canAccessAllTenants": true, "allowedTenantIds": [] }
  tenantPermissions Json @default("{}")

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users             User[]
  tenantAccessUsers UserTenantAccess[]
  publicLinks       PublicLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isSystem])
  @@index([roleType])
  @@index([tenantId, isDefault])
  @@index([tenantId, roleType])
}

// ═══════════════════════════════════════════════════════════════════════════
// USER TENANT ACCESS (Acesso multi-tenant por usuario)
// ═══════════════════════════════════════════════════════════════════════════

model UserTenantAccess {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  customRoleId String
  status       Status    @default(ACTIVE)
  grantedAt    DateTime  @default(now())
  expiresAt    DateTime?
  grantedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole CustomRole @relation(fields: [customRoleId], references: [id])

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([customRoleId])
}

// ═══════════════════════════════════════════════════════════════════════════
// PDF TEMPLATES (Templates de PDF customizaveis)
// ═══════════════════════════════════════════════════════════════════════════

model PdfTemplate {
  id       String @id @default(cuid())
  tenantId String

  name        String
  slug        String
  description String?
  icon        String?

  // Configuracoes de pagina
  pageSize    PdfPageSize    @default(A4)
  orientation PdfOrientation @default(PORTRAIT)
  margins     Json           @default("{\"top\":70,\"right\":70,\"bottom\":70,\"left\":70}")

  // Conteudo do template (estrutura JSON do editor visual)
  // Formato: { header: {...}, body: [...], footer: {...} }
  content Json @default("{}")

  // Entidade fonte de dados principal
  sourceEntityId String?
  sourceEntity   Entity? @relation(fields: [sourceEntityId], references: [id], onDelete: SetNull)

  // Campos selecionados da entidade
  selectedFields Json @default("[]")

  // Logo padrao do template
  logoUrl String?

  // Tipo de template: "single" (1 registro) ou "batch" (multiplos)
  templateType String @default("single")

  // Controle de versao e publicacao
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  version     Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generations PdfGeneration[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([sourceEntityId])
  @@index([isPublished])
  @@index([tenantId, isPublished])
}

// ═══════════════════════════════════════════════════════════════════════════
// PDF GENERATION (Historico de PDFs gerados)
// ═══════════════════════════════════════════════════════════════════════════

model PdfGeneration {
  id         String @id @default(cuid())
  tenantId   String
  templateId String

  // Status e progresso
  status   PdfGenerationStatus @default(PENDING)
  progress Int                 @default(0) // 0-100

  // IDs dos registros fonte
  recordIds Json @default("[]")

  // Resultado
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  pageCount Int?

  // Erro (se houver)
  errorMessage String?

  // Metadados adicionais
  metadata Json?

  // Quem solicitou
  requestedById String?
  requestedBy   User?   @relation(fields: [requestedById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // Relacionamentos
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template PdfTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([templateId])
  @@index([status])
  @@index([requestedById])
  @@index([createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
}

// ═══════════════════════════════════════════════════════════════════════════
// WEBHOOKS (Webhooks outbound para integracao)
// ═══════════════════════════════════════════════════════════════════════════

enum WebhookStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

model Webhook {
  id       String  @id @default(cuid())
  tenantId String
  entityId String?

  name         String
  description  String?
  url          String
  method       HttpMethod @default(POST)
  headers      Json? // { "Authorization": "Bearer {{secret}}", "Content-Type": "application/json" }
  bodyTemplate Json? // Template do body com placeholders

  // Eventos que disparam o webhook
  events String[] // ['created', 'updated', 'deleted', 'status-changed']

  // Filtros para disparar apenas em certas condicoes
  filterConditions Json? // [{ field, operator, value }]

  // Configuracoes
  status     WebhookStatus @default(ACTIVE)
  retryCount Int           @default(3)
  retryDelay Int           @default(1000) // ms entre retries
  timeout    Int           @default(30000) // ms

  // Seguranca
  secret String? // Para assinatura HMAC

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions WebhookExecution[]

  @@index([tenantId])
  @@index([entityId])
  @@index([status])
  @@index([tenantId, status])
  @@index([tenantId, entityId])
}

model WebhookExecution {
  id        String @id @default(cuid())
  webhookId String
  tenantId  String

  // Evento que disparou
  event    String
  recordId String?

  // Request
  requestUrl     String
  requestMethod  String
  requestHeaders Json?
  requestBody    Json?

  // Response
  responseStatus Int?
  responseBody   Json?
  responseTime   Int? // ms

  // Status
  status       String // 'success', 'error', 'timeout', 'retry'
  errorMessage String?
  retryCount   Int     @default(0)

  createdAt DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([webhookId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// EMAIL TEMPLATES (Templates de email customizaveis)
// ═══════════════════════════════════════════════════════════════════════════

model EmailTemplate {
  id       String @id @default(cuid())
  tenantId String

  name        String
  slug        String
  description String?

  // Conteudo
  subject  String
  bodyHtml String  @db.Text
  bodyText String? @db.Text

  // Variaveis disponiveis no template
  variables String[] // ['user.name', 'record.data.name', 'now']

  // Configuracoes
  fromName  String?
  fromEmail String?
  replyTo   String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([isActive])
  @@index([tenantId, isActive])
}

// ═══════════════════════════════════════════════════════════════════════════
// ACTION CHAINS (Cadeia de acoes automaticas)
// ═══════════════════════════════════════════════════════════════════════════

enum ActionChainTrigger {
  MANUAL // Disparado por botao
  WEBHOOK // Disparado por webhook recebido
  SCHEDULE // Disparado por cron
  EVENT // Disparado por evento (create, update, status-change)
}

model ActionChain {
  id       String  @id @default(cuid())
  tenantId String
  entityId String?

  name        String
  description String?
  trigger     ActionChainTrigger @default(MANUAL)

  // Configuracao do trigger
  // Para EVENT: { events: ['created', 'updated'], filterConditions: [...] }
  // Para SCHEDULE: { cronExpression: '0 9 * * *', timezone: 'America/Sao_Paulo' }
  // Para WEBHOOK: { path: '/hooks/my-action' }
  triggerConfig Json?

  // Acoes a executar em ordem
  // [{ order, type, config, inputMapping, condition }]
  // type: 'email' | 'webhook' | 'status-change' | 'notification' | 'wait'
  actions Json @default("[]")

  // Tratamento de erro
  errorHandling String @default("stop") // 'stop' | 'continue' | 'rollback'

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions ActionChainExecution[]

  @@index([tenantId])
  @@index([entityId])
  @@index([trigger])
  @@index([isActive])
  @@index([tenantId, isActive])
  @@index([tenantId, entityId])
}

model ActionChainExecution {
  id            String @id @default(cuid())
  actionChainId String
  tenantId      String

  // Contexto de execucao
  triggeredBy String // 'manual:userId', 'event:created', 'schedule:cron', 'webhook'
  recordId    String?
  inputData   Json?

  // Progresso
  currentStep Int    @default(0)
  totalSteps  Int    @default(0)
  status      String @default("running") // 'running', 'completed', 'failed', 'cancelled'

  // Resultado de cada acao
  // [{ step, type, status, input, output, error, duration }]
  stepResults Json @default("[]")

  errorMessage String?
  duration     Int? // ms total

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  actionChain ActionChain @relation(fields: [actionChainId], references: [id], onDelete: Cascade)

  @@index([actionChainId])
  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
  @@index([actionChainId, startedAt(sort: Desc)])
  @@index([tenantId, startedAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// SCHEDULED TASKS (Tarefas agendadas - Cron)
// ═══════════════════════════════════════════════════════════════════════════

model ScheduledTask {
  id       String  @id @default(cuid())
  tenantId String
  entityId String?

  name        String
  description String?

  // Cron
  cronExpression String
  timezone       String @default("America/Sao_Paulo")

  // Acao a executar
  // type: 'action-chain' | 'webhook' | 'email-report'
  actionType   String
  actionConfig Json?

  // Controle
  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?

  // Estatisticas
  runCount     Int @default(0)
  successCount Int @default(0)
  failureCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions ScheduledTaskExecution[]

  @@index([tenantId])
  @@index([entityId])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([tenantId, isActive])
}

model ScheduledTaskExecution {
  id              String @id @default(cuid())
  scheduledTaskId String
  tenantId        String

  status       String // 'success', 'error', 'timeout'
  duration     Int? // ms
  outputData   Json?
  errorMessage String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  scheduledTask ScheduledTask @relation(fields: [scheduledTaskId], references: [id], onDelete: Cascade)

  @@index([scheduledTaskId])
  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
  @@index([scheduledTaskId, startedAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// API EXECUTION LOG (Log de execucao de APIs e automacoes)
// ═══════════════════════════════════════════════════════════════════════════

model ApiExecutionLog {
  id            String  @id @default(cuid())
  tenantId      String
  customApiId   String?
  webhookId     String?
  actionChainId String?

  // Request
  method       String
  path         String
  inputPayload Json?
  userId       String?
  ip           String?

  // Response
  status        String // 'success', 'error', 'timeout', 'rate-limited'
  statusCode    Int?
  outputPayload Json?
  errorMessage  String?

  // Performance
  duration Int? // ms

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([customApiId])
  @@index([webhookId])
  @@index([actionChainId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
  @@index([customApiId, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTITY AUTOMATION (Sistema unificado de automacoes)
// ═══════════════════════════════════════════════════════════════════════════

enum AutomationTrigger {
  ON_CREATE
  ON_UPDATE
  ON_DELETE
  ON_FIELD_CHANGE
  ON_STATUS_CHANGE
  SCHEDULE
  MANUAL
}

model EntityAutomation {
  id       String @id @default(cuid())
  tenantId String
  entityId String

  name        String
  description String?
  isActive    Boolean @default(true)

  // Trigger
  trigger       AutomationTrigger
  triggerConfig Json? // ON_FIELD_CHANGE: { fieldSlug, fromValue?, toValue? }
  // ON_STATUS_CHANGE: { fromStatus?, toStatus? }
  // SCHEDULE: { cronExpression, timezone }

  // Condicoes para execucao (AND logico)
  conditions Json? // [{ field, operator, value }]

  // Acoes sequenciais
  actions Json @default("[]") // [{ order, type, config, condition? }]
  // Tipos: send_email, call_webhook, update_field, create_record,
  //        notify_user, change_status, wait

  errorHandling String @default("stop") // 'stop' | 'continue'

  // Rate limiting
  maxExecutionsPerHour Int @default(100)

  // Scheduling (para trigger SCHEDULE)
  lastRunAt DateTime?
  nextRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entity     Entity                @relation(fields: [entityId], references: [id], onDelete: Cascade)
  executions AutomationExecution[]

  @@index([tenantId])
  @@index([entityId])
  @@index([tenantId, entityId, isActive])
  @@index([trigger, isActive])
  @@index([nextRunAt])
}

model AutomationExecution {
  id           String  @id @default(cuid())
  automationId String
  tenantId     String
  recordId     String?

  triggeredBy String // 'system:on_create', 'user:<userId>', 'cron'
  inputData   Json?

  currentStep Int    @default(0)
  totalSteps  Int    @default(0)
  status      String @default("running") // 'running','completed','failed','cancelled'

  stepResults  Json    @default("[]")
  errorMessage String?
  duration     Int? // ms

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  automation EntityAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, startedAt(sort: Desc)])
  @@index([automationId, startedAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTITY FIELD RULES (Regras de campo: obrigatoriedade, visibilidade, etc.)
// ═══════════════════════════════════════════════════════════════════════════

model EntityFieldRule {
  id        String @id @default(cuid())
  tenantId  String
  entityId  String
  fieldSlug String

  ruleType String // 'required' | 'visible' | 'default' | 'computed' | 'validation'

  // Quando a regra se aplica (null = sempre)
  condition Json? // { field, operator, value }

  // Configuracao baseada no ruleType
  config Json

  priority Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId, fieldSlug])
  @@index([tenantId, entityId])
}

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD TEMPLATES
// ═══════════════════════════════════════════════════════════════════════════

model DashboardTemplate {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?

  // Entidade alvo (null = dashboard global)
  entitySlug String?

  // Layout do react-grid-layout: [{ i, x, y, w, h, minW, minH, maxW, maxH }]
  layout Json @default("[]")

  // Configuracoes dos widgets: { "widget-id": { type, title, config: {...} } }
  widgets Json @default("{}")

  // Abas do dashboard: [{ id, label, icon?, widgetIds[] }]
  tabs Json @default("[]")

  // IDs das CustomRoles atribuidas
  roleIds String[]

  // Prioridade (maior = preferencia quando multiplos templates para mesma role+entity)
  priority Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, entitySlug])
}

// ═══════════════════════════════════════════════════════════════════════════
// PUBLIC LINKS (Links publicos para formularios externos)
// ═══════════════════════════════════════════════════════════════════════════

model PublicLink {
  id       String @id @default(cuid())
  tenantId String

  // Token URL-safe para acesso publico: /p/{slug}
  slug String @unique

  // Entidade alvo
  entitySlug String
  entityId   String

  // Role atribuida a usuarios que se registram via este link
  customRoleId String

  // Metadados
  name        String // Nome amigavel (ex: "Inspecao de Caminhoes")
  description String?

  // Controles
  isActive          Boolean   @default(true)
  expiresAt         DateTime?
  maxUsers          Int?
  registrationCount Int       @default(0)

  // Configuracoes extras (logo, cor, mensagem de boas-vindas, etc.)
  settings Json @default("{}")

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id])
  customRole CustomRole @relation(fields: [customRoleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entitySlug])
}
